#include<bits/stdc++.h>
using namespace std;

int max(vector<int> a,int size)
{
    int m=a[0];
    for(int i=0;i<size;i++)
    {
        if(a[i]>m)m=a[i];
    }
    return m;
}

void cs(vector<int> &a,int n,int div)
{
    int output[n];
    int count[10]={0};
    for(int i=0;i<n;i++)
    {
        count[(a[i]/div)%10]++;
    }
    for(int i=1;i<10;i++)
    {
        count[i]=count[i]+count[i-1];
    }
    for(int i=n-1;i>=0;i--)
    {
        output[count[(a[i]/div)%10]-1]=a[i];
        count[(a[i]/div)%10]--;
    }
    for(int i=0;i<n;i++)
    {
        a[i]=output[i];
    }
}

void radixsort(vector<int> &a)
{
    int n=a.size();
    int M=max(a,n);
    for(int i=1;(M/i)>0;i*=10)
    {
        cs(a,n,i);
    }
    for(int i=0;i<n;i++)cout<<a[i]<<" ";
}

int main()
{
    cout<<"Enter values to sort(Enter anything except number values to stop): ";
    string s;
    vector<int> a;

    while (1)
    {
        cin >> s;
        if (isdigit(s[0]))
            a.push_back(stoi(s));
        else
            break;
    }

    radixsort(a);
}
